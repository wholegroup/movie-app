{
  "name": "movie-app",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engineStrict": true,
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "scripts": {
    "dev": "NEXT_PUBLIC_MOVIE_APP_VERSION=$(date -u +%y.%m.%d) next dev -p 3300 --webpack",
    "test": "vitest run",
    "storybook": "DEBUG= storybook dev -p 6006",
    "build-storybook": "storybook build",
    "analyze": "ANALYZE=true next build",
    "build": "NEXT_PUBLIC_MOVIE_APP_VERSION=$(date -u +%y.%m.%d) next build --webpack",
    "start": "next start -p 3400",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck"
  },
  "dependencies": {
    "@auth0/nextjs-auth0": "4.17.0",
    "@mdi/js": "7.4.47",
    "@mdi/react": "1.6.1",
    "@serwist/next": "9.5.7",
    "cron-parser": "5.5.0",
    "dexie": "4.4.2",
    "mobx": "6.15.0",
    "mobx-react-lite": "4.1.1",
    "next": "16.2.3",
    "photoswipe": "5.4.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "serwist": "9.5.7",
    "sqlite3": "6.0.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.2.3",
    "@storybook/addon-links": "10.3.5",
    "@storybook/nextjs": "10.3.5",
    "@storybook/react": "10.3.5",
    "@storybook/testing-library": "0.2.2",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.3",
    "eslint-plugin-storybook": "10.3.5",
    "jsdom": "29.0.2",
    "neostandard": "0.13.0",
    "storybook": "10.3.5",
    "vitest": "4.1.4"
  }
}
